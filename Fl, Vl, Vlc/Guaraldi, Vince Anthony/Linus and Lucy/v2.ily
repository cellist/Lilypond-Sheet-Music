vb = \relative c' {
  \voiceconsts

  R1*3
  r2.. d8~\mf
  \repeat volta 2 {
    d f b4-. b8 f d4-.
    f4. d8~ d4. d8~
    d f b4-. b2~
    b2. r8 d,~

    d f b4-. b8 f d4-.
    f4. d8~ d4. f8~
    f4. f8 f2~
    f2. r8 d~
    d4. f8 f2~
  }
  \alternative {
    { f2. r8 d }
    { f2. r4 }
  }
  g'8-> g-> g-> f-> r f[ \acciaccatura fis16 g8 g]
  f! g g f g g f r
  g-> g-> g-> <f b>-> r f[ \acciaccatura fis16 g8 g]
  
  f! g g f g g f r
  g-> g-> g-> <f b>-> r f[ \acciaccatura fis16 g8 g]
  f! g g f g g f r
  f,1~

  f2. r8 d~
  d f b4-. b8 f d4-.
  f4. d8~ d4. d8~
  d f b4-. b2~
  b2. r8 d,~

  d f b4-. b8 f d4-.
  f4. d8~ d4. f8~
  f4. f8 f2~
  f2. r8 d~
  d4. f8 f2~
  f2. r8 f~

  f4. f8 f2~
  f2. r8 d~
  d4. f8 f2~
  f1
  r4. a8~\f a a a4
  a f'~ f8 a, c f~

  f f4 c8~ c c f4
  es es~ es8 g, b es~
  es es4 b8~ b b g'4
  r8 fis, a d fis a, d fis

  r b, es g f! es a, c
  f a4.~ a8 c,4 c8
  f4 f8 f~ f f f4
  f8 f f4 f8 f f4

  f8 f f4 f8 f f4
  r8 g,4 b8 es4 es8 es~
  es b4 g8~ g b g4
  r8 fis a d fis a, d fis

  r b, es g f!4 h,8 e
  gis4 h8 gis e4 a,8 c
  f4 a8 f c a f'4 \bar "||"
  d,8\mf f b4-. b8 f d4-.

  f4. d8~ d4. d8~
  d f b4-. b2~
  b2. r8 d,~
  d f b4-. b8 f d4-.
  f4. d8~ d4. f8~

  f4. f8 f2~
  f2. r8 d~
  d4. f8 f2~
  f2. r8 f~
  f4. f8 f2~
  f2. r8 d~
  d4. f8 f2~
  f1 \bar "|."
}