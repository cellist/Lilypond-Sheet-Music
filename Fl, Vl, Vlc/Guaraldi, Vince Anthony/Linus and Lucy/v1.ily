va = \relative c'' {
  \voiceconsts

  R1*3
  r2.. b8~\mf
  \repeat volta 2 {
    b c d4-. d8 c b4-.
    c4. b8~ b4. b8~
    b c d4-. d2~
    d2. r8 b~

    b c d4-. d8 c b4-.
    c4. b8~ b4. b8~
    b4. c8 c2~
    c2. r8 b~
    b4. c8 c2~
  }
  \alternative {
    { c2. r8 b }
    { c2. r4 }
  }
  b'8-> b-> b-> b-> r b4 b8
  b g b b b b f r
  b-> b-> b-> b-> r b4 b8

  b g b b b b f r
  b-> b-> b-> b-> r b4 b8
  b g b b b b f r
  b,1~

  b2. r8 b~
  b c d4-. d8 c b4-.
  c4. b8~ b4. b8~
  b c d4-. d2~
  d2. r8 b~

  b c d4-. d8 c b4-.
  c4. b8~ b4. b8~
  b4. c8 c2~
  c2. r8 b~
  b4. c8 c2~
  c2. r8 b~

  b4. c8 c2~
  c2. r8 b~
  b4. c8 c2~
  c1
  r4. c8~\f c c f4
  f a~ a8 c, f a~

  a a4 f8~ f f a4
  g g~ g8 b, es g~
  g g4 es8~ es es g4
  r8 fis, a d fis a, d fis

  r b,8 es g f! es a, c
  f a4.~ a8 f4 f8
  a4 a8 b~ b b b4
  a8 a a4 b8 b b4

  a8 a a4 b8 b b4
  r8 es,4 f8 g4 as8 g~
  g f4 es8~ es f es4
  r8 fis, a? d fis a, d fis

  r b, es g f!4 h,8 e
  gis4 h8 gis e4 a,8 c
  f4 a8 f c a f'4 \bar "||"
  b,8\mf c d4-. d8 c b4-.

  c4. b8~ b4. b8~
  b c d4-. d2~
  d2. r8 b~
  b c d4-. d8 c b4-.
  c4. b8~ b4. b8~
  b4. c8 c2~

  c2. r8 b~
  b4. c8 c2~
  c2. r8 b~
  b4. c8 c2~
  c2. r8 b~
  b4. c8 c2
  b1 \bar "|."
}