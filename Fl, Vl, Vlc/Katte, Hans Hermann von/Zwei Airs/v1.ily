va = \relative c'' {
  \voiceconsts

  \introa
  h4 a8( g) a4 d
  g,8( e) a( g) fis( e) d4
  d' c8( h) a4 d
  d4.\trill cis8 d2~
  d8 e16( d c!8 h) c4 r

  R1
  g2~ g8 fis16( g a8) c
  h4 d8 c h4 r \bar "||"
  d g8( d) e4 d
  c8( h) c( d) h( a) g4

  a h8( fis) g4 fis
  g8( h) a( g) g4 fis
  r g g d
  e d d8( c) h( d)
  fis4 h, e g
  fis8 e d c \atc h2

  \introb
  c'4 g e c
  c' d e d
  c h8 a g4 e'
  d c h2\trill
  c, g'
  c g'

  R1*2
  d4 e d g
  f e d2
  c4 g e c
  f e d e
  a h c r

  \introc
  h a8( g) a4 d
  g,8( e) a( g) fis( e) d4
  d' c8( h) a4 d
  d4.\trill cis8 d2~
  d8 e16( d c!8 h) c4 r

  R1
  g2~ g8 fis16( g a8) c
  h4 d8 c h4 r \bar "||"
  d g8( d) e4 d
  c8( h) c( d) h( a) g4

  a h8( fis) g4 fis
  g8( h) a( g) g4 fis
  r g g d
  e d d8( c) h( d)
  fis4 h, e g
  fis8( e d c) h2 \fermata \bar "|."
}