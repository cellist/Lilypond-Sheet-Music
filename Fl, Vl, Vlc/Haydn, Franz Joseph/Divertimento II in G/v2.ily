vb = \relative c' {
  \voiceconsts

  \introa
  \repeat volta 2 {
    h4.(\mf g8) d' d
    h2.
    c4.( d8) e e
    \appoggiatura fis16 e8 d16 c h4 r
    r8 d'( c h a g)

    fis( e d c h) d'
    \appoggiatura d16 c8 h16 a g4 fis
    fis( g8) r4.
    r8 d'( c h a g)
    fis( e d c) h4
    \appoggiatura d'16 c8( h16 a) g4 fis

    g r2
    r8 g h16( g h g) d8 c
    h2 r4
    r8 cis e16 cis e cis a8 cis
    d d fis16 d fis d a8 d
    gis, d' gis16 d gis d gis8 d

    d4( cis8) r4.
    \repeat tremolo 6 a'8\p
    \repeat tremolo 6 g
    \repeat tremolo 4 b a a
    \repeat tremolo 6 a
    d16\f d, f a d8-. d,-. d'-. c?-.

    b16 b, d f b8-. b,-. b'-. a-.
    g?16 g, b d g8-. f-. e-. d-.
    gis16( a gis a) a,8 g' fis e
    d16 a fis' e d a fis' e d8 r
    e16 a, g' fis e a, g' fis e8 r

    fis16 d e fis g a h cis d e fis g
    fis4( e d)
    h8 h16 g fis4 e
    fis16( e d e) fis( d fis d) h'( g h g)

    fis( e d e) fis( d fis d) h'( g h g)
    fis8. e16 d4 cis
    a'16( g fis g) a( fis a fis) d'( h d h)
    a( g fis g) a( fis a fis) d'( h d h)

    a a' g e d4 cis
    d8 fis,16 d' fis8 fis \appoggiatura fis16 e8 d16 e
    d8 a,16 d fis8 fis \appoggiatura fis16 e8 d16 e
    e4( d) r
  }
  \repeat volta 2 {
    dis4.(\p h8) dis dis

    dis dis dis4 r
    dis4.( h8) dis dis
    dis dis dis4 r\fermata
    g4.(\p e8) g g
    g8.( e16) g4-. r
    f16( g f g) f( g f g) f( g f g)
    
    f( g f g) f( g f g) f( g f g)
    e\f d c d e c e c a' f a f
    e d c d e c e c a' f a f
    g f e f g e g e c' a c a

    g f e f g e g e c' a c a
    g8 e \repeat tremolo 4 e
    \repeat tremolo 6 e
    \repeat tremolo 6 d

    d16 h c d e fis g a h a g fis
    \repeat tremolo 6 e8
    d e16 fis g a h cis d cis d cis
    d4 r2

    h4.(\p g8) h-. h-.
    h g h2
    c?4.( d8) e-. e-.
    \appoggiatura fis16 e8 d16 c h4 r
    r8 d(\f c h a g)
    fis( e d c h) d'

    \appoggiatura d16 c8 h16 a g4 fis
    fis( g8) r4.
    R2.
    r8 e'(\fz d c h a)
    gis2 r4
    r8 e'(\fz d c h a)

    b2.
    a8 c( h! a g fis16 e)
    \repeat tremolo 6 d8
    \repeat tremolo 6 d
    \repeat tremolo 4 d d' d

    \appoggiatura d16 c8( h16 a) g4 fis\trill
    g r2
    \repeat tremolo 6 d8\p
    \repeat tremolo 6 c
    \repeat tremolo 4 es d d
    \repeat tremolo 6 d

    g16\f g, b d g8-. fis-. g-. a-.
    b16 b, d f b8-. a-. b-. c-.
    d16 d, g b d8-. b-. a-. g-.
    cis16( d cis d) d,8 c' h! a
    g16 d h' a g d h' a g8 r

    a16 d, c' h a d, c' h a8 r
    r fis16 g a h c d e fis g a
    h4( a) g8 d
    d16 c e c h4 a

    d16( c h c) d( h d h) g'( e g e)
    d( c h c) d( h d h) g'( e g e)
    d8 c16 a g4( fis)
    h,16( a g a) h( g h g) e'( c e c)

    h( a g a) h( g h g) e'( c e c)
    h8 c16 a' g4 fis
    g r8 h \appoggiatura h16 a8 g16 a
    g4 r8 d \appoggiatura d16 c8 h16 c
    c4( h8) r4.\fermata
  }

  \introb
  \repeat volta 2 {
    b4-.\mf b8-. b r b'
    a(-. a-. a)-. a r4
    fis4-. fis8-. fis r fis'
    g(-. g-. g)-. g r4

    b,,4-. b8-. b r d-.
    es-. r d-. c-. r b16 g'
    fis4-. fis8-. fis r cis'
    d4 fis,8-. fis-. r4
    d4-. d8-. d r d'

    g,4 r8 <c,? es>4 <c es>8
    <c es>4 r8 r4.
    b'8. c16 d8 d r4
    es8. f?16 g8 g r4

    b,8. c16 d8 d r4
    b,4. b'(~
    b16 a c b es d) c( b a g f es)
    \appoggiatura d d'8. c16 b8 b r b
    b4 g8 d8. es16 c8
    d'8. c16 b8 b r b
    b4 g8 d8. es16 c8
    d r d'-. d-. r4
  }

  d,8 r d' d r4
  h,16 d fis g f d h d fis g f d
  h c es g es c h c es g es c
  a c d fis d c b! d g a b g

  d fis a d a fis d8 r4
  b-. b8-. b r b'
  a(-. a-. a)-. a r4
  fis-. fis8-.  fis r fis'

  g(-. g-. g)-. g r4
  b,,-. b8-. b r d-.
  es-. r d-. c-. r b16 g'
  fis8 r4 g8\trill r4

  a8\trill r4 g8\trill r4
  cis,4.~\f cis8 r4
  r g'8-.\p g-. r fis-.
  fis-. r d'-. d-. r d,
  d4.\fermata r \bar "|."

  \introc
  \repeat volta 2 {
    g16\p d g d g d a' d,
    \repeat tremolo 4 { fis d }
    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 4 { g d }
    \repeat tremolo 2 { h' g } h g gis\fz h
    e, fis g! a fis\fz a fis a

    \repeat tremolo 2 { g d } \appoggiatura fis e8 d16 c
    h4 a8 r
  }
  \repeat volta 2 {
    \repeat tremolo 2 { c'16 d, } c' d, h' d,
    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 2 { a' d, } a' d, h' d,

    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 4 { g e }
    \repeat tremolo 4 { fis d }
    \repeat tremolo 2 { g d } g d a' d,
    \repeat tremolo 4 { fis d }
    
    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 4 { g d }
    \repeat tremolo 2 { h' g } h g gis\fz h
    e, fis g! a fis\fz a fis a
    \repeat tremolo 2 { g d } \appoggiatura h' a8 g16 fis
    g4 r
  } \key g \minor
  \repeat volta 2 {
    d'16 b a g fis g g, g'
    a, g' b, g' c, g' d g
    es c' a g fis es' d c
    \appoggiatura c8 b4\trill a8 r
    d16 b a g fis g g' d

    es g d g c, g' f! es
    d f b, d c es a, c
    b4 r
  }
  \repeat volta 2 {
    f'16 d c b a b d, b'
    es, b' f b g b f b
    e, d' c b a g' f es!

    d b' a g f e g e
    f g f e f c g' e
    f c es! b d a c g
    b f g es d f a, c
    b4 r8 d'
    d-. d-. d-. d-.

    d4 r8 d
    d d d d
    b d b g
    d4 r
    d'16 b a g fis g g, g'
    a, g' b, g' c, g' d g

    es c' a g fis es' d c
    \appoggiatura c8 b4\trill a8 r
    d16 b a g fis g g' d
    es g d g c, c' a fis
    g d es c b d fis, a
    g4 r
  } \key g \major
  \repeat volta 2 {
    \repeat tremolo 2 { g16\p d } g d a' d,
    \repeat tremolo 4 { fis d }
    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 4 { g d }
    \repeat tremolo 2 { h' g } h g gis\fz h
    e, fis g! a fis\fz a fis a

    \repeat tremolo 2 { g d } \appoggiatura fis e8 d16 c
    h4 a8 r
  }
  \repeat volta 2 {
    \repeat tremolo 2 { c'16 d, } c' d, h' d,
    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 2 { a' d, } a' d, h' d,

    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 4 { g e }
    \repeat tremolo 4 { fis d }
    \repeat tremolo 2 { g d } g d a' d,
    \repeat tremolo 4 { fis d }
    
    \repeat tremolo 2 { a' d, } a' d, h' d,
    \repeat tremolo 4 { g d }
    \repeat tremolo 2 { h' g } h g gis\fz h
    e, fis g! a fis\fz a fis a
    \repeat tremolo 2 { g d } \appoggiatura h' a8 g16 fis
  }
  \alternative {
    { g4 r }
    { g8 r c-. c-. }
  }
  h r a'16( g a fis)
  g8 r c,-.\p c-.
  h r a16( g a fis)
  g8 r4. \bar "|."
}