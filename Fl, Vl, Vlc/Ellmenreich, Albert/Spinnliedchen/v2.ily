vb = \relative c' {
  \voiceconsts

  R2*2
  a16(^\legg\mf b c d c8) a~->
  a c-. f4
  a,16( b c d c8) <a \parenthesize c>~->
  <a \parenthesize c> <b \parenthesize c>-. <a \parenthesize c>4
  a16( b c d c8) <a \parenthesize c>~->

  <a\parenthesize c> c-. f4
  a,16( b c d c8) <a \parenthesize c>~->
  <a \parenthesize c> <b \parenthesize c>-. a4
  r8 e'[-.\cresc r f]-.
  r fis[-. r g]-.
  b-. a-. g-. f!-.
  e-. <f g>->\f <e g>-> r
  r e[-.\p\cresc r f]-.

  r fis[-. r g]-.
  b-. a-. g-. f!-. \pori
  e\> c[( h b)]
  a16(\!\p b c d \atem c8) a~->
  a c-. f4
  a,16( b c d c8) <a \parenthesize c>~->
  <a \parenthesize c> <b \parenthesize c>-. <a \parenthesize c>4

  a16( b c d c8) a~->
  a c-. f4
  a,16( b c d c8) <a \parenthesize c>~->
  <a \parenthesize c> <b \parenthesize c>-. <a \parenthesize c>-. r
  \repeat tremolo 4 es'\p
  \repeat tremolo 4 es
  \repeat tremolo 4 d
  \repeat tremolo 4 d
  
  \repeat tremolo 4 es
  \repeat tremolo 4 es
  \repeat tremolo 4 d\>
  d\!\< d f f
  \repeat tremolo 4 f\!\p
  es es d d
  \repeat tremolo 4 es
  \repeat tremolo 4 d
  \repeat tremolo 4 <c d>
  <b d>\< <b d> d d
  \repeat tremolo 4 d
  cis\! r4.
  r8 d[\p d d]
  \repeat unfold 3 {
    r cis[ cis cis]
    r d[ d d]
  }
  cis r b-.\cresc r
  g-. r c!-.\! r
  R2*2
  
  a16(^\legg\mf b c d c8) a~->
  a c-. f4
  a,16( b c d c8) <a \parenthesize c>~->
  <a \parenthesize c> <b \parenthesize c>-. <a \parenthesize c>4
  a16( b c d c8) <a \parenthesize c>~->
  <a\parenthesize c> c-. f4
  a,16( b c d c8) <a \parenthesize c>~->
  
  <a \parenthesize c> <b \parenthesize c>-. a4
  r8 e'[-.\cresc r f]-.
  r fis[-. r g]-.
  b-. a-. g-. f!-.
  e-. <f g>->\f <e g>-> r
  r e[-.\p\cresc r f]-.
  r fis[-. r g]-.
  
  b-. a-. g-. f!-. \pori
  e\> c[( h b)]
  a16(\!\p b c d \atem c8) a~->
  a c-. f4
  a,16( b c d c8) <a \parenthesize c>~->
  <a \parenthesize c> <b \parenthesize c>-. <a \parenthesize c>4
  a16( b c d c8) a~->
  
  a c-. f4
  a,16( b c d c8) <a \parenthesize c>~->
  <a \parenthesize c> <b \parenthesize c>-. <a \parenthesize c>4~
  <a \parenthesize c>8 b a4~
  a8 b a b \rit
  a2~\<
  a~
  a4\! r \bar "|."
}