vc = \relative c' {
  \voiceconsts
  \clef "bass"

  a8\p e h' a g fis a g
  fis\pp a, h a \tuplet 3/2 4 { d, a' fis' } cis'[ h] r e, h' a g fis a g

  fis a, h a d, d' gis a ais cis, fis, cis' d cis fis cis
  e h cis d e d e cis fis, cis'4 ais'8 e, e'4 d'8

  a, g'4 d'8 cis g cis h r e, h' a g fis a g
  fis a, h a d, a' d a' r a e' d c h d c

  h d, e d g, g' cis! d dis fis, h, fis' g fis h fis
  a e fis g a g a fis dis' fis, h, fis' h fis h, fis

  e a g' a a g a, e \cona f d'4 c'8 fis,, d'4 c'8
  g, d'4 c'8 gis, d'4 c'8 \rit a, d4 c'8 ais, g'4 cis8

  h, g'4 d'8 b, gis'4 d'8 r fis, cis' h! a gis h a
  g! fis a g fis e h a r e'\pp h' a g fis a g

  fis a, h a \tuplet 3/2 4 { d, a' fis' } cis'[ h] r e, h' a g fis a g
  fis a, h a \tuplet 3/2 4 { d, a' fis' } d'[ a] r2 a,\ppp
  a\breve \bar "|."
}