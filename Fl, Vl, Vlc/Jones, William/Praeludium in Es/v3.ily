vc = \relative c, {
  \voiceconsts
  \clef "bass"

  f2 c'4 b8 a
  g g e c f4 a
  b4. g8 c4 d
  b c a r8 f

  f2 c
  d4 e f g
  a8 f c' c, f4 r8 f
  b c d b f4 a8 f

  g f e c f g a f
  b a g f c' c, e c
  d4 r16 g( a b) c4 d8 b
  c b c c, f4 r8 a

  f2 c'8 c, e cis
  d e f g a a, cis a
  f'4 cis d e
  f c! d r8 fis

  g g e c f! f d b
  e4 cis'8 a d,4 f8 d
  g2 a8[ a, r a']

  b4. b8 a4. a8
  g4 f c'? r8 c,
  d4 e f4. f8
  b,2 c8 e d f

  e g f a b4 g
  c f, c'2
  f4 es d b
  a b c c,
  f1\fermata \bar "|."
}