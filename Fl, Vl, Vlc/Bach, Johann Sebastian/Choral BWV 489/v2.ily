vb = \relative c' {
  \voiceconsts

  d4 e fis8( e) d4
  e e fis2\fermata
  fis4 h, e a,
  d cis8 h ais2\fermata

  fis'4. ais8 h( e,) fis4
  g fis8( e) d2\fermata
  fis8( e) d( fis) g4 d~
  d cis d2\fermata

  fis'4 fis8( e) e4 fis8( cis)
  d4 cis8( h) ais2\fermata
  cis8( d) e4 d8( e) fis4
  d cis8( h) h2\fermata

  h8( cis) d( cis) h4 fis
  fis gis fis2\fermata
  ais4 fis h2
  h4 ais fis2\fermata \bar "|."
}