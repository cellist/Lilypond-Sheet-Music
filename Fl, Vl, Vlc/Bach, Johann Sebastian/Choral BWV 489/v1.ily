va = \relative c'' {
  \voiceconsts

  h4 ais8( h) h( fis) fis4
  d' cis8( h) ais2\fermata
  a!4 h8( fis) g4 a8( e)
  fis4 e fis2\fermata

  fis'8( cis) cis4 d8( a) a4
  h a8 g fis2\fermata
  a4 a h8( cis) d4
  fis, e8( d) d2\fermata

  h'8( cis) d( cis) h4 fis
  fis gis fis2\fermata
  ais4 fis h2
  h4 ais h8\fermata cis d e

  fis4 fis8( e) e4 fis8( cis)
  d4 cis8( h) ais2\fermata
  cis8( d) e4 d8( e) fis4
  d cis8( h) h2\fermata \bar "|."
}