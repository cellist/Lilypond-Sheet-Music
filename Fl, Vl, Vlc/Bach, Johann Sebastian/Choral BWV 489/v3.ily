vc = \relative c {
  \voiceconsts
  \clef "bass"

  h4 cis d8 cis h a
  gis4 g fis2\fermata
  fis'8 e dis4 e8 d cis4
  d8 h g'4 fis2\fermata

  ais4. fis8 h cis d4
  g, a d,2\fermata
  d8 e fis d g4 fis8 g
  a4 a, d2\fermata

  d'8 cis h2 ais4
  h eis, fis2\fermata
  fis4 gis8 ais h4 d,8 e!
  fis4 fis, h2\fermata

  d'8 cis h2 ais4
  h eis, fis2\fermata
  fis4 gis8 ais h4 d,8 e!
  fis4 fis, h2\fermata \bar "|."
}