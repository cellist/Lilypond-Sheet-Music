va = \relative c'' {
  \voiceconsts

  \repeat volta 2 {
    R2.
    h4 h e
    dis e fis
    g fis e
    dis2 r4
    R2.
    g,4 a h8 c

    h2 r4
    R2.
    r2 d?4~
    d f e8 d
    e4 d c
    h a4.\prall g8
    g2 r4
    r g a

    g8 fis? d4 r
    fis fis g
    a2 r4
    R2.*3
    r4 g c
    c fis h,
    h e ais,

    h2.
    R2.*2
    r4 h g'
    g cis, fis
    fis h, e~
    e8 d cis4.\prall h8
    h2 r4
  }
  \repeat volta 2 {
    R2.*4
    g4 g a
    h2.~
    h2 e4~
    e2 r4
    dis dis e

    fis2 h,4~
    h r2
    r4 a f'
    f2 e4
    e2 d4
    gis, a h
    c d e

    f h,4.\prall a8
    a2 r4
    R2.*2
    d4 a8 h c d
    h2.
    g'4 d f
    e2 r4
    fis? fis e

    dis2 r4
    e e8 d! c h
    c2 h4
    a a g8 fis
    h4. a8 h4
    c fis,4. e8
    e2 r4
  }
}