vc = \relative c {
  \voiceconsts
  \clef "bass"
  
  \repeat volta 2 {
    R2.*3
    e4 fis a
    h a g8 fis
    g4 fis h,
    e fis d

    g2 h4
    c h a
    g d2
    g g4
    c h a
    g d2
    h4 h c
    d g fis

    d2 r4
    R2.
    r4 a' h
    c2 c4
    cis2 cis4
    d2 dis4
    e e,2
    d?2.
    c?
    h2 r4
    r h' cis
    ais h cis
    d2 h4
    a?2.
    g2 g4
    e fis2
    h r4
  }
  \repeat volta 2 {
    h, h cis
    dis dis e
    fis fis g
    a g fis
    e e fis
    g g a
    h a g
    c? h a
    h h cis

    dis2 r4
    d! c? h
    a2 h4~
    h d2
    c h4
    e,2.~
    e2 a4

    f2 e4
    r a h
    cis2.
    d2 cis4
    d2 r4
    r g, a
    h2.
    r4 c? h
    ais2 fis?4

    h2 fis4
    e2 e4
    a2 e4~
    e dis h
    e4. fis8 g4
    a h h,
    e2 r4
  }
}