va = \relative c''' {
  \voiceconsts

  d4(\p h) h( d)
  d( a) a( d)
  d-- g,( fis e)
  fis2 d8( e16 fis h a h cis)

  d4( h) h( d)
  d( a) a( d)
  d-- g,( fis e)
  d1
  h'4( g) g( h)

  a( fis) fis( a)
  g(\< a h d)
  e(\!\> cis a g)
  h(\! g) g( h)
  a( fis) fis( a)

  g(\< a h d) \rall
  cis2\fermata\!\> r\!
  d4( \atem h) h( d)
  d( a) a( d)
  d-- g,( fis e)

  fis2 d8( e16 fis g a h cis)
  d4( h) h( d)
  d( a) a( d)
  d-- g,( fis e)

  d1
  e4(\pp d e d)
  fis( e) g( fis) \rall
  h( a h e)
  d1 \bar "|."
}